<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的云盘 · 简洁版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif;
            background: linear-gradient(145deg, #f6f9fc 0%, #edf2f9 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .app-container {
            max-width: 1100px;
            width: 100%;
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 36px;
            box-shadow: 0 20px 40px rgba(0,20,50,0.15), 0 8px 20px rgba(0,0,0,0.05);
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.5);
        }

        /* 头部区域 */
        .header {
            background: rgba(255,255,255,0.8);
            padding: 24px 32px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo h1 {
            font-size: 26px;
            font-weight: 600;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .user-area {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            background: white;
            padding: 6px 16px 6px 12px;
            border-radius: 40px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        }

        .avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(145deg, #4f6d9a, #2b4a78);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 18px;
        }

        .username {
            font-weight: 500;
            color: #1a2639;
        }

        .logout-btn {
            background: none;
            border: none;
            color: #8899bb;
            cursor: pointer;
            font-size: 14px;
            padding: 6px 12px;
            border-radius: 30px;
            transition: all 0.2s;
        }
        .logout-btn:hover {
            background: #eef2f6;
            color: #d32f2f;
        }

        .auth-buttons {
            display: flex;
            gap: 12px;
        }
        .btn-outline, .btn-primary {
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            font-size: 14px;
            border: 1.5px solid transparent;
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-outline {
            background: white;
            border-color: #cbd5e1;
            color: #334155;
        }
        .btn-outline:hover {
            background: #f1f5f9;
            border-color: #94a3b8;
        }
        .btn-primary {
            background: #1e3c72;
            color: white;
            box-shadow: 0 4px 12px rgba(30,60,114,0.25);
        }
        .btn-primary:hover {
            background: #2a4a82;
            transform: translateY(-1px);
        }

        /* 存储空间卡片 */
        .storage-card {
            background: white;
            margin: 24px 32px;
            padding: 20px 28px;
            border-radius: 24px;
            box-shadow: 0 6px 14px rgba(0,10,30,0.06);
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            border: 1px solid rgba(0,0,0,0.02);
        }

        .storage-info h3 {
            font-size: 15px;
            font-weight: 500;
            color: #62748c;
            margin-bottom: 6px;
        }

        .storage-progress {
            width: 280px;
            height: 10px;
            background: #e3e9f2;
            border-radius: 20px;
            overflow: hidden;
            margin: 8px 0 4px;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #2a5c9a, #3b7bc9);
            border-radius: 20px;
            width: 0%;
            transition: width 0.3s ease;
        }

        .storage-text {
            font-size: 14px;
            color: #334155;
        }
        .storage-text strong {
            color: #1e3c72;
            font-weight: 600;
        }

        .upload-btn {
            background: #2a5c9a;
            border: none;
            color: white;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 8px 18px rgba(42,92,154,0.3);
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .upload-btn:hover {
            background: #316bb3;
            transform: scale(1.02);
            box-shadow: 0 12px 24px rgba(42,92,154,0.35);
        }

        /* 文件列表工具栏 */
        .toolbar {
            padding: 8px 32px 16px;
            display: flex;
            gap: 16px;
            align-items: center;
            flex-wrap: wrap;
        }
        .path-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.6);
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 14px;
        }
        .path-item {
            color: #2a5298;
            font-weight: 500;
            cursor: pointer;
        }
        .path-item:hover {
            text-decoration: underline;
        }
        .path-sep {
            color: #b0c4de;
        }

        .view-options {
            margin-left: auto;
            display: flex;
            gap: 8px;
        }
        .view-btn {
            background: white;
            border: 1px solid #dde3ed;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 500;
            color: #3a4e6b;
            cursor: pointer;
        }
        .view-btn.active {
            background: #1e3c72;
            color: white;
            border-color: #1e3c72;
        }

        /* 文件网格 */
        .file-grid {
            padding: 12px 32px 32px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 20px;
        }

        .file-item {
            background: white;
            border-radius: 24px;
            padding: 20px 12px 14px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0,0,0,0.02);
            transition: 0.2s;
            border: 1px solid rgba(0,0,0,0.02);
            cursor: pointer;
            position: relative;
        }
        .file-item:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 30px rgba(20,40,70,0.12);
            border-color: rgba(42,82,152,0.2);
        }

        .file-icon {
            font-size: 48px;
            line-height: 1;
            margin-bottom: 10px;
        }
        .file-name {
            font-weight: 500;
            font-size: 14px;
            color: #1e293b;
            word-break: break-word;
            max-width: 120px;
            margin: 0 auto 6px;
        }
        .file-meta {
            font-size: 11px;
            color: #7e8aa8;
        }
        .file-checkbox {
            position: absolute;
            top: 12px;
            left: 12px;
            width: 18px;
            height: 18px;
            accent-color: #2a5c9a;
            cursor: pointer;
        }

        /* 空状态 */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            color: #8a9bb5;
            font-size: 15px;
        }

        /* 底部批量操作栏 */
        .batch-bar {
            background: white;
            margin: 0 32px 28px;
            padding: 14px 24px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            gap: 24px;
            box-shadow: 0 -2px 12px rgba(0,0,0,0.02);
            border: 1px solid #ecf1f7;
        }
        .batch-actions {
            display: flex;
            gap: 16px;
        }
        .batch-btn {
            background: none;
            border: none;
            color: #49658c;
            font-weight: 500;
            font-size: 14px;
            padding: 6px 16px;
            border-radius: 30px;
            cursor: pointer;
        }
        .batch-btn.danger {
            color: #c62828;
        }
        .batch-btn:hover {
            background: #f0f5fd;
        }

        /* 模态框 */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,10,20,0.5);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal.active {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 40px;
            width: 380px;
            max-width: 90%;
            padding: 32px 28px;
            box-shadow: 0 40px 70px rgba(0,20,40,0.4);
        }
        .modal-content h2 {
            margin-bottom: 24px;
            color: #1e2f4a;
            font-weight: 600;
        }
        .modal-content input {
            width: 100%;
            padding: 16px 18px;
            border: 1px solid #dce3ec;
            border-radius: 30px;
            margin-bottom: 16px;
            font-size: 15px;
            background: #fafcff;
        }
        .modal-actions {
            display: flex;
            gap: 12px;
            margin-top: 16px;
        }
        .modal-actions button {
            flex: 1;
            padding: 14px;
            border-radius: 40px;
            font-weight: 600;
            border: none;
            cursor: pointer;
        }
        .modal-btn-primary {
            background: #1e3c72;
            color: white;
        }
        .modal-btn-secondary {
            background: #eef3fa;
            color: #2d3f5e;
        }
    </style>
</head>
<body>
<div class="app-container" id="app">

    <!-- 头部 -->
    <div class="header">
        <div class="logo"><h1>☁️ 我的云盘</h1></div>
        <div class="user-area" id="userArea">
            <!-- 登录后显示用户信息 -->
            <div class="user-info" id="userInfo" style="display: none;">
                <span class="avatar" id="userAvatar">U</span>
                <span class="username" id="userName">加载中...</span>
                <button class="logout-btn" id="logoutBtn">退出</button>
            </div>
            <!-- 未登录显示按钮 -->
            <div class="auth-buttons" id="authButtons">
                <button class="btn-outline" id="showLoginBtn">登录</button>
                <button class="btn-primary" id="showRegisterBtn">注册</button>
            </div>
        </div>
    </div>

    <!-- 存储卡片（登录后显示） -->
    <div class="storage-card" id="storageCard" style="display: none;">
        <div class="storage-info">
            <h3>存储空间</h3>
            <div class="storage-progress"><div class="progress-fill" id="storageProgressFill" style="width:0%"></div></div>
            <div class="storage-text"><span id="storageUsed">0</span> / <span id="storageTotal">10</span> GB</div>
        </div>
        <button class="upload-btn" id="uploadBtn">📤 上传文件</button>
    </div>

    <!-- 文件导航工具栏（登录后显示） -->
    <div class="toolbar" id="toolbar" style="display: none;">
        <div class="path-nav" id="pathNav">
            <span class="path-item" data-path="">全部文件</span>
        </div>
        <div class="view-options">
            <button class="view-btn active" data-view="grid">网格</button>
            <button class="view-btn" data-view="list">列表</button>
        </div>
    </div>

    <!-- 文件网格 -->
    <div class="file-grid" id="fileGrid"></div>

    <!-- 批量操作栏 -->
    <div class="batch-bar" id="batchBar" style="display: none;">
        <span id="selectedCount">已选择 0 项</span>
        <div class="batch-actions">
            <button class="batch-btn" id="batchDownloadBtn">📥 下载</button>
            <button class="batch-btn" id="batchMoveBtn">📁 移动</button>
            <button class="batch-btn danger" id="batchDeleteBtn">🗑️ 删除</button>
        </div>
    </div>

    <!-- 登录模态框 -->
    <div class="modal" id="loginModal">
        <div class="modal-content">
            <h2>登录</h2>
            <input type="text" placeholder="用户名" id="loginUsername">
            <input type="password" placeholder="密码" id="loginPassword">
            <div class="modal-actions">
                <button class="modal-btn-secondary" onclick="closeModal('loginModal')">取消</button>
                <button class="modal-btn-primary" id="loginBtn">登录</button>
            </div>
        </div>
    </div>

    <!-- 注册模态框 -->
    <div class="modal" id="registerModal">
        <div class="modal-content">
            <h2>注册</h2>
            <input type="text" placeholder="用户名" id="regUsername">
            <input type="email" placeholder="邮箱" id="regEmail">
            <input type="password" placeholder="密码" id="regPassword">
            <input type="password" placeholder="确认密码" id="regConfirm">
            <div class="modal-actions">
                <button class="modal-btn-secondary" onclick="closeModal('registerModal')">取消</button>
                <button class="modal-btn-primary" id="registerBtn">注册</button>
            </div>
        </div>
    </div>
</div>

<script>
    // 配置
    const API_BASE = '';  // 留空表示同域名，或者写你的IP: http://124.221.102.153
    let TOKEN = localStorage.getItem('token') || null;
    let currentUser = null;
    let currentFiles = [];

    // DOM 元素
    const userInfo = document.getElementById('userInfo');
    const authButtons = document.getElementById('authButtons');
    const storageCard = document.getElementById('storageCard');
    const toolbar = document.getElementById('toolbar');
    const fileGrid = document.getElementById('fileGrid');
    const batchBar = document.getElementById('batchBar');
    const userNameSpan = document.getElementById('userName');
    const userAvatar = document.getElementById('userAvatar');

    // 初始化检查登录状态
    if (TOKEN) {
        fetchUserProfile();
    } else {
        showLoggedOutUI();
    }

    // ================== UI 辅助函数 ==================
    function showLoggedInUI(user) {
        userInfo.style.display = 'flex';
        authButtons.style.display = 'none';
        storageCard.style.display = 'flex';
        toolbar.style.display = 'flex';
        userNameSpan.textContent = user.username || '用户';
        userAvatar.textContent = (user.username || 'U').charAt(0).toUpperCase();
        // 获取存储信息
        fetchStorageInfo();
        // 获取文件列表
        fetchFiles();
    }

    function showLoggedOutUI() {
        userInfo.style.display = 'none';
        authButtons.style.display = 'flex';
        storageCard.style.display = 'none';
        toolbar.style.display = 'none';
        batchBar.style.display = 'none';
        fileGrid.innerHTML = '<div class="empty-state">请先登录</div>';
        TOKEN = null;
        currentUser = null;
        localStorage.removeItem('token');
    }

    // ================== API 调用 ==================
    async function apiCall(endpoint, options = {}) {
        const url = API_BASE + '/api/v1' + endpoint;
        const headers = {
            'Content-Type': 'application/json',
            ...(options.headers || {})
        };
        if (TOKEN) {
            headers['Authorization'] = 'Bearer ' + TOKEN;
        }
        const response = await fetch(url, { ...options, headers });
        const data = await response.json();
        if (!response.ok) {
            throw new Error(data.message || '请求失败');
        }
        return data;
    }

    async function fetchUserProfile() {
        try {
            const res = await apiCall('/profile');
            currentUser = res.data;
            showLoggedInUI(currentUser);
        } catch (e) {
            console.error('获取用户信息失败', e);
            showLoggedOutUI();
        }
    }

    async function fetchStorageInfo() {
        try {
            const res = await apiCall('/storage');
            const storage = res.data;
            const usedGB = (storage.used / (1024*1024*1024)).toFixed(2);
            const totalGB = (storage.capacity / (1024*1024*1024)).toFixed(2);
            document.getElementById('storageUsed').innerText = usedGB;
            document.getElementById('storageTotal').innerText = totalGB;
            const percent = (storage.used / storage.capacity) * 100;
            document.getElementById('storageProgressFill').style.width = percent + '%';
        } catch (e) {
            console.error('获取存储信息失败', e);
        }
    }

    async function fetchFiles(parentId = '') {
        try {
            const url = parentId ? `/files?parent_id=${parentId}` : '/files';
            const res = await apiCall(url);
            currentFiles = res.data.files || [];
            renderFiles(currentFiles);
        } catch (e) {
            console.error('获取文件列表失败', e);
            fileGrid.innerHTML = '<div class="empty-state">加载失败，请重试</div>';
        }
    }

    function renderFiles(files) {
        if (!files || files.length === 0) {
            fileGrid.innerHTML = '<div class="empty-state">📂 还没有文件，点击上传按钮添加</div>';
            batchBar.style.display = 'none';
            return;
        }
        let html = '';
        files.forEach(file => {
            const size = file.size_text || file.size + ' B';
            const icon = file.is_dir ? '📁' : '📄';
            html += `
                <div class="file-item" data-id="${file.id}" data-isdir="${file.is_dir}">
                    <input type="checkbox" class="file-checkbox" data-id="${file.id}">
                    <div class="file-icon">${icon}</div>
                    <div class="file-name">${file.filename}</div>
                    <div class="file-meta">${size}</div>
                </div>
            `;
        });
        fileGrid.innerHTML = html;
        
        // 给文件项添加双击事件
        document.querySelectorAll('.file-item').forEach(item => {
            item.addEventListener('dblclick', (e) => {
                const isDir = item.dataset.isdir === 'true';
                if (isDir) {
                    fetchFiles(item.dataset.id);
                }
            });
        });
        
        // 复选框事件更新批量栏
        document.querySelectorAll('.file-checkbox').forEach(cb => {
            cb.addEventListener('change', updateBatchBar);
        });
    }

    function updateBatchBar() {
        const checked = document.querySelectorAll('.file-checkbox:checked').length;
        if (checked > 0) {
            batchBar.style.display = 'flex';
            document.getElementById('selectedCount').innerText = `已选择 ${checked} 项`;
        } else {
            batchBar.style.display = 'none';
        }
    }

    // ================== 登录注册 ==================
    document.getElementById('showLoginBtn').addEventListener('click', () => openModal('loginModal'));
    document.getElementById('showRegisterBtn').addEventListener('click', () => openModal('registerModal'));

    document.getElementById('loginBtn').addEventListener('click', async () => {
        const username = document.getElementById('loginUsername').value;
        const password = document.getElementById('loginPassword').value;
        try {
            const res = await apiCall('/login', {
                method: 'POST',
                body: JSON.stringify({ username, password })
            });
            TOKEN = res.data.token;
            localStorage.setItem('token', TOKEN);
            closeModal('loginModal');
            fetchUserProfile();
        } catch (e) {
            alert('登录失败：' + e.message);
        }
    });

    document.getElementById('registerBtn').addEventListener('click', async () => {
        const username = document.getElementById('regUsername').value;
        const email = document.getElementById('regEmail').value;
        const password = document.getElementById('regPassword').value;
        const confirm = document.getElementById('regConfirm').value;
        if (password !== confirm) {
            alert('两次密码不一致');
            return;
        }
        try {
            await apiCall('/register', {
                method: 'POST',
                body: JSON.stringify({ username, email, password, confirm_password: confirm })
            });
            alert('注册成功，请登录');
            closeModal('registerModal');
        } catch (e) {
            alert('注册失败：' + e.message);
        }
    });

    document.getElementById('logoutBtn').addEventListener('click', () => {
        showLoggedOutUI();
    });

    // ================== 上传文件 ==================
    document.getElementById('uploadBtn').addEventListener('click', () => {
        const input = document.createElement('input');
        input.type = 'file';
        input.onchange = async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            const formData = new FormData();
            formData.append('file', file);
            
            try {
                const response = await fetch(API_BASE + '/api/v1/files/upload', {
                    method: 'POST',
                    headers: {
                        'Authorization': 'Bearer ' + TOKEN
                    },
                    body: formData
                });
                const data = await response.json();
                if (data.code === 0) {
                    alert('上传成功');
                    fetchFiles(); // 刷新列表
                } else {
                    alert('上传失败：' + data.message);
                }
            } catch (err) {
                alert('上传出错：' + err.message);
            }
        };
        input.click();
    });

    // ================== 模态框 ==================
    function openModal(id) {
        document.getElementById(id).classList.add('active');
    }
    function closeModal(id) {
        document.getElementById(id).classList.remove('active');
    }
    window.closeModal = closeModal;

    // 点击模态框背景关闭
    document.querySelectorAll('.modal').forEach(modal => {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) modal.classList.remove('active');
        });
    });

    // ================== 批量操作 ==================
    document.getElementById('batchDeleteBtn').addEventListener('click', async () => {
        const checked = document.querySelectorAll('.file-checkbox:checked');
        if (checked.length === 0) return;
        const ids = Array.from(checked).map(cb => cb.dataset.id);
        if (!confirm(`确定删除 ${ids.length} 个文件吗？`)) return;
        
        try {
            await apiCall('/files/batch', {
                method: 'DELETE',
                body: JSON.stringify({ file_ids: ids })
            });
            alert('删除成功');
            fetchFiles();
        } catch (e) {
            alert('删除失败：' + e.message);
        }
    });

    // ================== 初始加载 ==================
    if (TOKEN) {
        fetchUserProfile();
    } else {
        showLoggedOutUI();
    }
</script>
</body>
</html>