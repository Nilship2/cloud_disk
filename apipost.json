{
  "info": {
    "name": "云盘系统 API",
    "description": "仿百度网盘的后端系统，支持文件存储、分享、收藏等功能",
    "version": "1.0.0",
    "baseUrl": "http://localhost:8080/api/v1"
  },
  "folders": [
    {
      "name": "01-用户管理",
      "description": "用户注册、登录、个人信息管理"
    },
    {
      "name": "02-文件管理",
      "description": "文件上传、下载、列表、操作"
    },
    {
      "name": "03-文件夹管理",
      "description": "文件夹创建"
    },
    {
      "name": "04-分享管理",
      "description": "文件分享、访问、下载"
    },
    {
      "name": "05-收藏管理",
      "description": "文件收藏、取消、列表"
    },
    {
      "name": "06-回收站管理",
      "description": "回收站列表、恢复、彻底删除"
    },
    {
      "name": "07-系统监控",
      "description": "健康检查、系统统计"
    }
  ],
