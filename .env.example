# .env.example
# 服务器配置
CLOUD_DISK_SERVER_ENV=development
CLOUD_DISK_SERVER_PORT=8080

# 数据库配置
CLOUD_DISK_DB_HOST=localhost
CLOUD_DISK_DB_PORT=3306
CLOUD_DISK_DB_USERNAME=root
CLOUD_DISK_DB_PASSWORD=password
CLOUD_DISK_DB_NAME=cloud_disk

# Redis配置
CLOUD_DISK_REDIS_HOST=localhost
CLOUD_DISK_REDIS_PORT=6379

# JWT配置
CLOUD_DISK_JWT_SECRET=your-secret-key-change-in-production

# 存储配置
CLOUD_DISK_STORAGE_TYPE=local

# MinIO配置（备用）
#CLOUD_DISK_MINIO_ENDPOINT=localhost:9000
#CLOUD_DISK_MINIO_ACCESS_KEY=minioadmin
#CLOUD_DISK_MINIO_SECRET_KEY=minioadmin
#CLOUD_DISK_MINIO_USE_SSL=false

# S3配置（备用）
#CLOUD_DISK_S3_REGION=us-east-1
#CLOUD_DISK_S3_ACCESS_KEY=your-access-key
#CLOUD_DISK_S3_SECRET_KEY=your-secret-key
#CLOUD_DISK_S3_BUCKET_NAME=cloud-disk-bucket